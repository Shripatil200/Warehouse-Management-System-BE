# ===========================
# WMS - .gitignore
# Java / Spring Boot / Maven
# ===========================

# Compiled class files
*.class

# Maven build output
target/
!.mvn/wrapper/maven-wrapper.jar

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/

# Eclipse
.classpath
.project
.settings/

# macOS
.DS_Store

# ===================================================
# SECURITY - NEVER COMMIT SECRETS
# ===================================================
application-local.yml
application-local.properties
*.env
.env
.env.*

# ===================================================
# Node / Frontend (should not exist in a BE project)
# ===================================================
node_modules/
npm-debug.log*
yarn-error.log*

# Log files
*.log
logs/

# Spring Boot DevTools restart file
.spring-boot-devtools.properties

# JVM crash logs
hs_err_pid*
replay_pid*
